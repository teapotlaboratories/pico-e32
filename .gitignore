# ESP-IDF out-of-source build output (Makefile puts it under build/<APP>/<BOARD>/)
/build/

# ESP-IDF toolchain / Python venv (self-contained SDK tools; IDF_TOOLS_PATH)
/vendor/.espressif/

# generated sdkconfig — board defaults live in boards/, app defaults in the app dir
**/sdkconfig
**/sdkconfig.old

# component manager artifacts
**/managed_components/
**/dependencies.lock

# host build artifact
firmware/pico-e32-luabench/host/bench
*.o

# third-party benchmark cart (Celeste Classic) — game code, do NOT commit/redistribute.
# Regenerate locally with assets/gen_celeste_cart.py
assets/celeste.p8
assets/celeste_cart.h
# PNG-encoded carts (same third-party game code as the .p8 above, just PNG-wrapped) — do NOT commit
assets/*.p8.png

# editor / OS cruft
.DS_Store

# bench-camera local config + captured frames (churn/binaries)
tools/bench_cam.env
captures/
assets/celeste_p8.h
# rendered sim|device comparison videos (regenerable via test/playtest/celeste/render_compare.py)
test/playtest/celeste/videos/

# downloaded ROM/cart archives + in-progress downloads (user-local game content, not repo source)
/assets/roms/
*.part
assets/pico_racer_p8.h
