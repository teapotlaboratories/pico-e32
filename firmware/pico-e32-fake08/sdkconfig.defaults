# App-level config for pico-e32-fake08. Board/target/PSRAM come from boards/<BOARD>/sdkconfig.defaults
# (layered first by the top-level Makefile).

# app_main runs fake-08's GameLoop directly; the Lua pcall path + graphics calls want a roomy C stack.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=32768

CONFIG_COMPILER_OPTIMIZATION_PERF=y

# Frame pacing: the GameLoop caps at 30 fps with vTaskDelay, which sleeps in whole FreeRTOS ticks.
# At the IDF default 100 Hz (10 ms/tick) a 33.3 ms target quantizes to ±10 ms — frames land at
# 20/30/40 ms and the game visibly judders even though the per-frame WORK is only ~6 ms (measured:
# Step 2.6 ms + drawFrame 3.6 ms). A 1 ms tick gives the pacer 1 ms granularity → smooth 30 fps.
CONFIG_FREERTOS_HZ=1000

# z8lua opcode dispatch is faster with jump tables (see components/z8lua/CMakeLists.txt); the component
# already forces them for the interpreter.

# SD cart loader: FATFS long filenames (default IDF uses 8.3 short names, which mangle/hide .p8 cart
# names). LFN_HEAP (not _STACK — the main task stack is already stretched for Lua); UTF-8 so non-ASCII
# cart names survive.
CONFIG_FATFS_LFN_HEAP=y
CONFIG_FATFS_MAX_LFN=255
CONFIG_FATFS_API_ENCODING_UTF_8=y

# Assertions OFF (release/perf) — pairs with COMPILER_OPTIMIZATION_PERF above. A fresh sdkconfig defaults
# compiler assertions ON (level 2), and on this esp-idf/newlib the FIRST printh at boot (fwrite -> the newlib
# recursive stdio lock, __retarget_lock_acquire_recursive) trips FreeRTOS' configASSERT (= plain assert()) on
# an otherwise-working stdio path, boot-looping any ASCII-telemetry (printh) build. This pins the config the
# board was actually validated under (cleared Celeste deterministically + measured fps). The underlying strict
# stdio-lock check is benign here; see docs/worklog/2026-07-20-celeste-closed-loop-fc-scheduled.md.
CONFIG_COMPILER_OPTIMIZATION_ASSERTIONS_DISABLE=y

# UART-only console. This board talks over its CP2104 UART, NOT USB-Serial-JTAG, but a fresh sdkconfig defaults
# the ESP32-S3 SECONDARY console to USB-Serial-JTAG — which adds a second stdout path whose recursive stdio lock
# is what tripped the boot assert above, and (with the assert masked) corrupts the cart's first printh so the
# Lua coroutine dies (fc frozen at 1, no player spawns). Pin the console to UART-only, matching the validated
# config the board was actually developed + demoed under.
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y
