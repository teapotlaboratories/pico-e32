# Copy to tools/bench_cam.env (gitignored) and set the bench camera's IP.
# The IP is printed over UART on boot: "bench-cam ready: http://<ip>/capture"
BENCH_CAM_HOST=192.168.1.42

# Lens de-distortion + upright rotation (applied by capture_frame.sh via tools/undistort.py, and by
# record_video.sh via ffmpeg lenscorrection). The defaults are baked into the tools; override here only if
# your camera/mount differs. Tune k1 so the panel's straight edges stop bowing (more negative = correct
# stronger barrel; too negative pincushions). BENCH_CAM_ROTATE = cw|ccw|180|none is the coarse 90° mount
# turn; BENCH_CAM_FINE_ROTATE is extra CW degrees to level the residual tilt.
#BENCH_CAM_K1=-0.36       # OpenCV radial coeff for stills
#BENCH_CAM_K2=0.0
#BENCH_CAM_ROTATE=cw
#BENCH_CAM_FINE_ROTATE=4.0  # extra CW degrees (level the mount tilt)
#BENCH_CAM_UNDISTORT=0    # set to skip de-distortion and keep the raw sensor frame
#VIDEO_LENS=cx=0.5:cy=0.5:k1=-0.22:k2=0   # ffmpeg lenscorrection for video (matches OpenCV k1=-0.36)
#VIDEO_FINE_ROTATE=4.0    # ffmpeg extra CW degrees for video (matches BENCH_CAM_FINE_ROTATE)
