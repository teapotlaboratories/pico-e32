# Board: Espressif ESP-EYE (ESP32-WROVER + OV2640/OV3660, 4 MB flash + PSRAM).
#
# This is NOT a target board for the handheld — it is the bench capture camera aimed
# at the panel under test (hardware-in-the-loop verification, see
# docs/hardware/pico-e32-bench-camera.md). Only pico-e32-bench-cam builds for it.
CONFIG_IDF_TARGET="esp32"
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# Camera framebuffers need PSRAM.
CONFIG_SPIRAM=y
CONFIG_SPIRAM_USE_MALLOC=y
